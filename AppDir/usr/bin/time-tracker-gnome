#!/bin/bash
set -e
APPDIR="${APPDIR:-$(dirname "$(readlink -f "$0")")/../..}"
export APPDIR
export PYTHONPATH="${APPDIR}/usr/lib/python3/dist-packages:${APPDIR}/usr/share/time-tracker-gnome:${PYTHONPATH:-}"
export PYTHONHOME="${APPDIR}/usr"
export XDG_DATA_DIRS="${APPDIR}/usr/share:${XDG_DATA_DIRS:-}"
export LD_LIBRARY_PATH="${APPDIR}/usr/lib/x86_64-linux-gnu:${APPDIR}/usr/lib:${LD_LIBRARY_PATH:-}"
export GI_TYPELIB_PATH="${APPDIR}/usr/lib/x86_64-linux-gnu/girepository-1.0"
export GSETTINGS_SCHEMA_DIR="${APPDIR}/usr/share/glib-2.0/schemas"
export GDK_PIXBUF_MODULE_FILE="${APPDIR}/usr/lib/x86_64-linux-gnu/gdk-pixbuf-2.0/2.10.0/loaders.cache"
exec "${APPDIR}/usr/bin/python3" "${APPDIR}/usr/share/time-tracker-gnome/main.py" "$@"
